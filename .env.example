# ── MQTT Broker ─────────────────────────────────────────────────────────
# IP or hostname of the Mosquitto broker.
# - If running locally on the Pi:     MQTT_BROKER=127.0.0.1
# - If on another machine on LAN:     MQTT_BROKER=192.168.1.x
# - If on another machine via TS:     MQTT_BROKER=100.x.x.x
MQTT_BROKER=your-mqtt-broker-ip
MQTT_PORT=1883

# ── MQTT Broker Auth (optional — uncomment if set up) ──────────────────
# See docs/deployment.md "MQTT broker security" to set up a password file.
# MQTT_USERNAME=mochisuki
# MQTT_PASSWORD=your-password-here
# MQTT_TLS=true

# ── Webhook Secret (phase 2 — uncomment when webhook is wired) ────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# WEBHOOK_SECRET=your-webhook-secret-here
